#!/usr/bin/make -f

export DH_VERBOSE = 1

%:
	dh $@

# The BPF binaries under src/bin/ are produced by the top-level
# Makefile before packaging. Nothing to do here.
override_dh_auto_build:

override_dh_auto_test:

override_dh_auto_install:
	# Application tree under /opt/aodv2
	install -d -m 0755 debian/aodv2/opt/aodv2
	cp -a src debian/aodv2/opt/aodv2/src
	install -m 0644 pyproject.toml debian/aodv2/opt/aodv2/pyproject.toml

	# Configuration (auto-detected as conffile because it lives under /etc)
	install -D -m 0644 config/config.yaml debian/aodv2/etc/aodv2/config.yaml

	# systemd unit (dh_installsystemd picks it up under lib/systemd/system)
	install -D -m 0644 aodv2.service \
	    debian/aodv2/lib/systemd/system/aodv2.service
