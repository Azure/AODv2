#!/usr/bin/make -f

export DH_VERBOSE = 1

%:
	dh $@

# The BPF binaries under src/bin/ are produced by the top-level
# Makefile before packaging. Nothing to do here.
override_dh_auto_build:

override_dh_auto_test:

# systemd unit is picked up automatically from debian/aodv2.service by dh_installsystemd.
override_dh_auto_install:

