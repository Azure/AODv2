#!/usr/bin/make -f

%:
    dh $@

override_dh_auto_install:
    # Install the Python package
    python3 setup.py install --root=$(DESTDIR)

    # Install the systemd service file
    install -D -m 644 src/aodv2.service $(DESTDIR)/lib/systemd/system/aodv2.service

    # Install the configuration file
    install -D -m 644 config/config.yaml $(DESTDIR)/etc/aodv2/config.yaml

    # Install the controller script
    install -D -m 755 src/controller $(DESTDIR)/usr/bin/aodv2_controller

    # Ensure the output directory exists
    mkdir -p $(DESTDIR)/var/log/aodv2

override_dh_systemd_enable:
    dh_systemd_enable -p$(package) aodv2.service

override_dh_systemd_start:
    dh_systemd_start -p$(package) aodv2.service