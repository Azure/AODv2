# /etc/aodv2/aodv2.env
#
# systemd EnvironmentFile for aodv2.service.
# Any KEY=VALUE line here becomes an environment variable for the daemon and
# overrides the corresponding Environment= line in aodv2.service.
#
# AOD_PYTHON
#   Python interpreter the daemon runs under. The unit ships a fallback of
#   /usr/bin/python3, which is >= 3.11 on all currently-supported
#   Debian/Ubuntu/Fedora releases and is satisfied by the python3-numpy,
#   python3-pyyaml (python3-yaml on Debian) and python3-zstandard packages
#   pulled in by the aodv2 rpm/deb dependencies. Leave commented to use
#   that fallback.
#
#   Set this if the default python3 on your host is older than 3.11
#
#AOD_PYTHON=/usr/bin/python3.11
#
#   To run the daemon inside your own virtual environment instead:
#     python3 -m venv /opt/aodv2-venv
#     /opt/aodv2-venv/bin/pip install numpy PyYAML zstandard
#   then uncomment and set:
#
#AOD_PYTHON=/opt/aodv2-venv/bin/python
